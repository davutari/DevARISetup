<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette -->
    <Color x:Key="SidebarDark">#FF1A1A2E</Color>
    <Color x:Key="SidebarMid">#FF16213E</Color>
    <Color x:Key="ContentBg">#FF0F0F1A</Color>
    <Color x:Key="CardBg">#FF1E1E30</Color>
    <Color x:Key="CardHover">#FF2A2A40</Color>
    <Color x:Key="AccentPurple">#FF7C3AED</Color>
    <Color x:Key="AccentTeal">#FF14B8A6</Color>
    <Color x:Key="AccentBlue">#FF3B82F6</Color>
    <Color x:Key="SuccessGreen">#FF22C55E</Color>
    <Color x:Key="WarningYellow">#FFEAB308</Color>
    <Color x:Key="ErrorRed">#FFEF4444</Color>
    <Color x:Key="TextPrimary">#FFFAFAFA</Color>
    <Color x:Key="TextSecondary">#FF9CA3AF</Color>
    <Color x:Key="TextMuted">#FF6B7280</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarDark}" />
    <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBg}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHover}" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}" />
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTeal}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreen}" />
    <SolidColorBrush x:Key="WarningYellowBrush" Color="{StaticResource WarningYellow}" />
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SidebarDark}" Offset="0" />
        <GradientStop Color="{StaticResource SidebarMid}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentPurple}" Offset="0" />
        <GradientStop Color="{StaticResource AccentTeal}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PurpleGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7C3AED" Offset="0" />
        <GradientStop Color="#FF9333EA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TealGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF14B8A6" Offset="0" />
        <GradientStop Color="#FF06B6D4" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3B82F6" Offset="0" />
        <GradientStop Color="#FF6366F1" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF97316" Offset="0" />
        <GradientStop Color="#FFEF4444" Offset="1" />
    </LinearGradientBrush>

    <!-- Card Style -->
    <Style x:Key="DashCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Margin" Value="8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource CardHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Nav Button Style -->
    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#30967AED" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section Title -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Stat Number -->
    <Style x:Key="StatNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="StatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#99FFFFFF" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

</ResourceDictionary>
