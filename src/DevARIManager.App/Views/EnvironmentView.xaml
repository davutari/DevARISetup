<UserControl x:Class="DevARIManager.App.Views.EnvironmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DevARIManager.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
        <converters:BoolToTextConverter x:Key="BoolToText" />
        <converters:EnvStatusToColorConverter x:Key="EnvStatusToColor" />
    </UserControl.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Ortam &amp; PATH Yönetimi" Style="{StaticResource SectionTitle}" FontSize="28" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                    <Run Text="{Binding MissingPathCount}" FontWeight="Bold" Foreground="{StaticResource ErrorRedBrush}" />
                    <Run Text=" eksik PATH, " />
                    <Run Text="{Binding MissingEnvCount}" FontWeight="Bold" Foreground="{StaticResource WarningYellowBrush}" />
                    <Run Text=" eksik ortam değişkeni" />
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource MaterialDesignFlatMidBgButton}" Background="{StaticResource AccentPurpleBrush}" Foreground="White"
                        Command="{Binding FixAllPathsCommand}" Padding="16,8" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="10" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AutoFix" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Tümünü Düzelt" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatMidBgButton}" Background="#20FFFFFF" Foreground="{StaticResource TextSecondaryBrush}"
                        Command="{Binding RefreshCommand}" Padding="16,8" materialDesign:ButtonAssist.CornerRadius="10" FontSize="12">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Ortam Değişkenleri -->
                <TextBlock Text="Ortam Değişkenleri" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                <ItemsControl ItemsSource="{Binding EnvironmentVariables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                                             Fill="{Binding Status, Converter={StaticResource EnvStatusToColor}}" VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2" Text="{Binding Value}" FontSize="12" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Column="3" Text="{Binding RelatedTool}" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- PATH Girileri -->
                <TextBlock Text="PATH Girişleri" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,24,0,12" />

                <ItemsControl ItemsSource="{Binding PathEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Grid.Column="0" Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center"
                                        Kind="{Binding Exists, Converter={StaticResource BoolToText}, ConverterParameter=CheckCircle|CloseCircle}"
                                        Foreground="{Binding Exists, Converter={StaticResource BoolToColor}, ConverterParameter=#FF22C55E|#FFEF4444}" />

                                    <TextBlock Grid.Column="1" Text="{Binding Path}" FontSize="12" FontFamily="Consolas"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2" Text="{Binding RelatedTool}" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="12,0,12,0" />

                                    <Button Grid.Column="3" Content="Ekle" Command="{Binding AddToPathCommand}"
                                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                            Background="{StaticResource AccentTealBrush}" Foreground="White"
                                            FontSize="11" Padding="12,4" materialDesign:ButtonAssist.CornerRadius="6"
                                            Visibility="{Binding Exists, Converter={StaticResource InvBoolToVis}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
