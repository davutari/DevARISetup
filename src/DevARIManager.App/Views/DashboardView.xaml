<UserControl x:Class="DevARIManager.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DevARIManager.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
        <converters:BoolToTextConverter x:Key="BoolToText" />
        <converters:StringToColorConverter x:Key="StringToColor" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="32,24">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource SectionTitle}" FontSize="28" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                        <TextBlock Text="  |  " Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                        <TextBlock Text="{Binding SystemInfo}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Background="{StaticResource AccentPurpleBrush}"
                        Foreground="White" materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding RefreshCommand}" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Yenile" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Loading -->
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" Margin="0,40">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="48" Height="48" />
                <TextBlock Text="Sistem taranıyor..." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Stats Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,24" Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                <!-- Installed Tools -->
                <Border Style="{StaticResource DashCard}">
                    <Border Background="{StaticResource PurpleGradient}" CornerRadius="14" Padding="20">
                        <StackPanel>
                            <Grid>
                                <materialDesign:PackIcon Kind="Toolbox" Width="28" Height="28" Foreground="#99FFFFFF" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBlock Style="{StaticResource StatNumber}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}/{1}">
                                        <Binding Path="InstalledCount" />
                                        <Binding Path="TotalCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="Kurulu Arac" Style="{StaticResource StatLabel}" />
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Running Services -->
                <Border Style="{StaticResource DashCard}">
                    <Border Background="{StaticResource TealGradient}" CornerRadius="14" Padding="20">
                        <StackPanel>
                            <Grid>
                                <materialDesign:PackIcon Kind="ServerNetwork" Width="28" Height="28" Foreground="#99FFFFFF" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBlock Text="{Binding RunningServices}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="Aktif Servis" Style="{StaticResource StatLabel}" />
                        </StackPanel>
                    </Border>
                </Border>

                <!-- PATH Issues -->
                <Border Style="{StaticResource DashCard}">
                    <Border Background="{StaticResource OrangeGradient}" CornerRadius="14" Padding="20">
                        <StackPanel>
                            <Grid>
                                <materialDesign:PackIcon Kind="AlertCircle" Width="28" Height="28" Foreground="#99FFFFFF" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBlock Text="{Binding PathIssues}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="PATH Sorunu" Style="{StaticResource StatLabel}" />
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Updates -->
                <Border Style="{StaticResource DashCard}">
                    <Border Background="{StaticResource BlueGradient}" CornerRadius="14" Padding="20">
                        <StackPanel>
                            <Grid>
                                <materialDesign:PackIcon Kind="Update" Width="28" Height="28" Foreground="#99FFFFFF" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBlock Text="{Binding UpdatesAvailable}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="Güncelleme" Style="{StaticResource StatLabel}" />
                        </StackPanel>
                    </Border>
                </Border>
            </UniformGrid>

            <!-- Quick Profiles -->
            <Border Style="{StaticResource DashCard}" Margin="8,0,8,8" Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22" Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="Hizli Profiller" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding QuickProfiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="12" Padding="16,14" Margin="4">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="44" Height="44" CornerRadius="12" Background="#20967AED" HorizontalAlignment="Center" Margin="0,0,0,10">
                                            <materialDesign:PackIcon Kind="{Binding IconKind}" Width="22" Height="22"
                                                                     Foreground="{StaticResource AccentPurpleBrush}"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0">
                                            <Run Text="{Binding ToolCount}" /><Run Text=" arac" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Tools & Services Row -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Recent Tools -->
                <Border Grid.Column="0" Style="{StaticResource DashCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Toolbox" Width="22" Height="22" Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Araçlar" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding RecentTools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0"
                                                     Fill="{Binding IsInstalled, Converter={StaticResource BoolToColor}, ConverterParameter=#FF22C55E|#FF6B7280}" />

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Quick Services -->
                <Border Grid.Column="1" Style="{StaticResource DashCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="ServerNetwork" Width="22" Height="22" Foreground="{StaticResource AccentTealBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Hizli Servisler" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding QuickServices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0"
                                                     Fill="{Binding IsRunning, Converter={StaticResource BoolToColor}, ConverterParameter=#FF22C55E|#FFEF4444}" />

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="Port: {0}">
                                                            <Binding Path="Port" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToText}, ConverterParameter=Aktif|Kapali}" FontSize="10"
                                                           Foreground="{Binding IsRunning, Converter={StaticResource BoolToColor}, ConverterParameter=#FF22C55E|#FFEF4444}" />
                                            </Border>

                                            <Button Grid.Column="3"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Padding="4" Width="32" Height="32"
                                                    Command="{Binding DataContext.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ServiceId}">
                                                <materialDesign:PackIcon Width="16" Height="16"
                                                    Kind="{Binding IsRunning, Converter={StaticResource BoolToText}, ConverterParameter=Stop|Play}"
                                                    Foreground="{Binding IsRunning, Converter={StaticResource BoolToColor}, ConverterParameter=#FFEF4444|#FF22C55E}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Activity (Terminal Preview) -->
            <Border Style="{StaticResource DashCard}" Margin="8,0,8,8" Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="Console" Width="22" Height="22" Foreground="{StaticResource AccentTealBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="Son Aktiviteler" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#FF0D0D14" CornerRadius="10" Padding="12,8" MinHeight="60">
                        <ItemsControl ItemsSource="{Binding RecentLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="{Binding Time}" FontSize="10" FontFamily="Consolas" Foreground="#FF4B5563" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Message}" FontSize="11" FontFamily="Consolas" TextWrapping="NoWrap" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding Color, Converter={StaticResource StringToColor}}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
