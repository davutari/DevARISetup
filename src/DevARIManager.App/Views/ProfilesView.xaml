<UserControl x:Class="DevARIManager.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DevARIManager.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Profiller" Style="{StaticResource SectionTitle}" FontSize="28" />
            <TextBlock Text="Hazır profil seçerek tüm araçları tek tıkla yükleyin" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
        </StackPanel>

        <!-- Install Progress Banner -->
        <Border Grid.Row="1" Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource CardBgBrush}" CornerRadius="14" Padding="20" Margin="0,12,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="24" Height="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="{Binding SelectedProfile.Name}" /><Run Text=" kurulumu devam ediyor..." />
                            </TextBlock>
                            <TextBlock Text="{Binding InstallStatus}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}">
                        <Run Text="{Binding CurrentStep}" /><Run Text="/" /><Run Text="{Binding TotalSteps}" />
                    </TextBlock>
                </Grid>
                <ProgressBar Value="{Binding InstallProgress}" Maximum="100" Height="6"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             Foreground="{StaticResource AccentPurpleBrush}" />
            </StackPanel>
        </Border>

        <!-- Profile Cards Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="360" Background="{StaticResource CardBgBrush}" CornerRadius="16" Padding="24" Margin="0,0,16,16">
                            <StackPanel>
                                <!-- Icon + Title -->
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="48" Height="48" CornerRadius="12" Background="#20967AED">
                                            <materialDesign:PackIcon Kind="{Binding IconKind}" Width="24" Height="24"
                                                                     Foreground="{StaticResource AccentPurpleBrush}"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding ToolCount}" /><Run Text=" arac" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12" />

                                <!-- Tool Tags -->
                                <Border Background="#10FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,0,16">
                                    <TextBlock Text="{Binding ToolNames}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" FontFamily="Consolas" />
                                </Border>

                                <!-- Install Button -->
                                <Button Content="Profili Kur"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        Background="{StaticResource AccentPurpleBrush}" Foreground="White"
                                        materialDesign:ButtonAssist.CornerRadius="10"
                                        FontSize="13" Padding="20,10" HorizontalAlignment="Stretch"
                                        Command="{Binding DataContext.InstallProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
