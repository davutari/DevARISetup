<UserControl x:Class="DevARIManager.App.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DevARIManager.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:IntToVisibilityConverter x:Key="IntToVis" />
        <converters:StringToColorConverter x:Key="StringToColor" />
    </UserControl.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Terminal" Style="{StaticResource SectionTitle}" FontSize="28" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding TotalEntries}" FontWeight="Bold" /><Run Text=" kayit" />
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    <TextBlock Foreground="{StaticResource SuccessGreenBrush}" FontSize="12">
                        <Run Text="{Binding SuccessCount}" FontWeight="Bold" /><Run Text=" başarılı" />
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    <TextBlock Foreground="{StaticResource WarningYellowBrush}" FontSize="12">
                        <Run Text="{Binding WarningCount}" FontWeight="Bold" /><Run Text=" uyarı" />
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    <TextBlock Foreground="{StaticResource ErrorRedBrush}" FontSize="12">
                        <Run Text="{Binding ErrorCount}" FontWeight="Bold" /><Run Text=" hata" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                    Background="#20FFFFFF" Foreground="{StaticResource TextSecondaryBrush}"
                    materialDesign:ButtonAssist.CornerRadius="10"
                    Command="{Binding ClearCommand}" Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DeleteSweep" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="Temizle" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <Border Grid.Column="0" Background="#10FFFFFF" CornerRadius="8" Padding="10,6" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimaryBrush}"
                                 FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"
                                 materialDesign:HintAssist.Hint="Ara..." materialDesign:HintAssist.IsFloating="False" />
                    </Grid>
                </Border>

                <!-- Level Filter Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Hepsi" FontSize="10" Padding="10,4"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="#20FFFFFF" Foreground="{StaticResource TextSecondaryBrush}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Command="{Binding FilterByLevelCommand}" CommandParameter="All" Margin="0,0,4,0" />
                    <Button Content="Hata" FontSize="10" Padding="10,4"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="#20EF4444" Foreground="{StaticResource ErrorRedBrush}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Command="{Binding FilterByLevelCommand}" CommandParameter="Error" Margin="0,0,4,0" />
                    <Button Content="Uyari" FontSize="10" Padding="10,4"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="#20EAB308" Foreground="{StaticResource WarningYellowBrush}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Command="{Binding FilterByLevelCommand}" CommandParameter="Warning" Margin="0,0,4,0" />
                    <Button Content="OK" FontSize="10" Padding="10,4"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="#2022C55E" Foreground="{StaticResource SuccessGreenBrush}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Command="{Binding FilterByLevelCommand}" CommandParameter="Success" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding TotalEntries, Converter={StaticResource IntToVis}, ConverterParameter=invert}">
            <materialDesign:PackIcon Kind="Console" Width="64" Height="64" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Henüz log kaydı yok" FontSize="14" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="Kurulum veya servis işlemleri başlattığınızda loglar burada görünecek" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Terminal Output -->
        <Border Grid.Row="2" Background="#FF0D0D14" CornerRadius="14" Padding="4" ClipToBounds="True"
                Visibility="{Binding TotalEntries, Converter={StaticResource IntToVis}}">
            <ListBox x:Name="TerminalListBox" ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,4" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65" />
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Timestamp -->
                            <TextBlock Grid.Column="0" Text="{Binding Timestamp}" FontSize="11"
                                       FontFamily="Consolas" Foreground="#FF4B5563" />

                            <!-- Level Tag -->
                            <Border Grid.Column="1" CornerRadius="3" Padding="4,1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding Color, Converter={StaticResource StringToColor}}" Opacity="0.2" />
                                </Border.Background>
                                <TextBlock Text="{Binding LevelTag}" FontSize="9" FontWeight="Bold" FontFamily="Consolas">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding Color, Converter={StaticResource StringToColor}}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>

                            <!-- Source -->
                            <TextBlock Grid.Column="2" FontSize="11" FontFamily="Consolas" Foreground="#FF6366F1" Margin="8,0,8,0">
                                <Run Text="[" /><Run Text="{Binding Source}" /><Run Text="]" />
                            </TextBlock>

                            <!-- Message -->
                            <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="11"
                                       FontFamily="Consolas" TextWrapping="Wrap">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding Color, Converter={StaticResource StringToColor}}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
