<UserControl x:Class="DevARIManager.App.Views.HealthCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:DevARIManager.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:HealthStatusToColorConverter x:Key="HealthToColor" />
        <converters:HealthStatusToIconConverter x:Key="HealthToIcon" />
    </UserControl.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Sağlık Taraması" Style="{StaticResource SectionTitle}" FontSize="28" />
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                    Background="{StaticResource AccentPurpleBrush}" Foreground="White"
                    Command="{Binding RunScanCommand}" Padding="16,8" materialDesign:ButtonAssist.CornerRadius="10"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InvBoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="HeartPulse" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Tarama Başlat" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Scanning Progress -->
        <StackPanel Grid.Row="1" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="14" Padding="24">
                <StackPanel>
                    <TextBlock Text="Tarama devam ediyor..." FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Foreground="{StaticResource AccentPurpleBrush}" />
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,8,0,0">
                        <Run Text="%" /><Run Text="{Binding Progress}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Results Summary -->
        <StackPanel Grid.Row="1" Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
            <UniformGrid Columns="3">
                <Border Background="#30229954" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="24" Height="24" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,0,10,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding HealthyCount}" FontSize="22" FontWeight="Bold" /><Run Text=" Basarili" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#30EAB308" CornerRadius="12" Padding="16" Margin="4,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="24" Height="24" Foreground="{StaticResource WarningYellowBrush}" Margin="0,0,10,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding WarningCount}" FontSize="22" FontWeight="Bold" /><Run Text=" Uyari" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#30EF4444" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CloseCircle" Width="24" Height="24" Foreground="{StaticResource ErrorRedBrush}" Margin="0,0,10,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding ErrorCount}" FontSize="22" FontWeight="Bold" /><Run Text=" Hata" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>

        <!-- No Scan Yet -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasResults, Converter={StaticResource InvBoolToVis}}">
            <materialDesign:PackIcon Kind="HeartPulse" Width="64" Height="64" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Henüz tarama yapılmadı" FontSize="16" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,4" HorizontalAlignment="Center" />
            <TextBlock Text="Yukarıdaki butona tıklayarak sistem taraması başlatabilirsiniz" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Results List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,14,0" VerticalAlignment="Center"
                                         Fill="{Binding Status, Converter={StaticResource HealthToColor}}" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ToolName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Message}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="2" Visibility="{Binding CanAutoFix, Converter={StaticResource BoolToVis}}"
                                        Background="#30967AED" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="Otomatik Düzelt" FontSize="10" Foreground="{StaticResource AccentPurpleBrush}" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
