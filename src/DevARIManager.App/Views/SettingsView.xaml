<UserControl x:Class="DevARIManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ayarlar" Style="{StaticResource SectionTitle}" FontSize="28" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <!-- Genel -->
                <TextBlock Text="Genel" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                <Border Background="{StaticResource CardBgBrush}" CornerRadius="14" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Koyu Tema" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Karanlık arayüz temasını kullan" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <ToggleButton HorizontalAlignment="Right" IsChecked="{Binding IsDarkTheme}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Başlangıçta Güncelleme Kontrolü" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Uygulama açıldığında araç güncellemelerini kontrol et" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <ToggleButton HorizontalAlignment="Right" IsChecked="{Binding CheckUpdatesOnStartup}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,16" />

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Servisleri Otomatik Başlat" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Windows ile birlikte servisleri başlat" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <ToggleButton HorizontalAlignment="Right" IsChecked="{Binding AutoStartServices}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Kurulum -->
                <TextBlock Text="Kurulum Tercihleri" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,16" />

                <Border Background="{StaticResource CardBgBrush}" CornerRadius="14" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Tercih Edilen Paket Yöneticisi" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox SelectedItem="{Binding PreferredInstaller}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Foreground="{StaticResource TextPrimaryBrush}" FontSize="13">
                            <ComboBoxItem Content="winget" />
                            <ComboBoxItem Content="Chocolatey" />
                            <ComboBoxItem Content="Scoop" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Hakkında -->
                <TextBlock Text="Hakkında" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,16" />

                <Border Background="{StaticResource CardBgBrush}" CornerRadius="14" Padding="20" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource AccentGradient}" Margin="0,0,14,0">
                                <materialDesign:PackIcon Kind="RocketLaunch" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DevARI Manager" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding AppVersion, StringFormat=Versiyon {0}}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="ARI Akademi - Developer Tools Manager" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="Öğrencilerinizi kurulum derdinden kurtarın." FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <Button Content="Kaydet"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="{StaticResource AccentPurpleBrush}" Foreground="White"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            FontSize="14" Padding="32,10"
                            Command="{Binding SaveCommand}" />
                    <TextBlock Text="{Binding SaveStatus}" FontSize="12" Foreground="{StaticResource SuccessGreenBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
